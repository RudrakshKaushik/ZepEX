# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,your-api-domain.com

# development | local = Gmail SMTP
# testing = Resend (e.g. Render deploy)
# production = not configured yet
ENVIRONMENT=development

# Comma-separated full URLs (include https://). Example for production:
# DJANGO_CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app
DJANGO_CORS_ALLOWED_ORIGINS=
DJANGO_CSRF_TRUSTED_ORIGINS=
DATABASE_URL=postgresql://postgres:demo@127.0.0.1:5432/demo
REDIS_URL=redis://localhost:6379/0

# Required for receipt AI extraction (Google AI Studio)
GEMINI_API_KEY=

# Set False in production when running Celery worker + Redis
CELERY_TASK_ALWAYS_EAGER=True

# --- development / local (Gmail SMTP) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-gmail-app-password
DEFAULT_FROM_EMAIL=your@gmail.com
EMAIL_USE_TLS=True

# --- testing on Render (Resend) — set ENVIRONMENT=testing on the host ---
# RESEND_API_KEY=re_xxxx
# DEFAULT_FROM_EMAIL=onboarding@resend.dev

# Exchange rate API (used for multi-currency reimbursement)
EXCHANGE_RATE_PROVIDER=ExchangeRate API
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6
EXCHANGE_RATE_API_KEY=
