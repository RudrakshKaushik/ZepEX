# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# PostgreSQL (optional — omit to use local socket defaults)
# DATABASE_NAME=your_db_name
# DATABASE_USER=postgres
# DATABASE_PASSWORD=
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432

DJANGO_CORS_ALLOWED_ORIGINS=
DJANGO_CSRF_TRUSTED_ORIGINS=
DATABASE_URL=postgresql://postgres:demo@127.0.0.1:5432/demo
REDIS_URL=redis://localhost:6379/0

# Required for receipt AI extraction (Google AI Studio)
GEMINI_API_KEY=

# Set False in production when running Celery worker + Redis
CELERY_TASK_ALWAYS_EAGER=True
